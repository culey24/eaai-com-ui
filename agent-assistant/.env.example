# Backend API (tools gọi HTTP vào BE)
# Host chạy backend Node: dùng localhost. Docker một container (run-docker.sh): bắt buộc host máy — vd.:
# BE_SERVER_BASE_URL=http://host.docker.internal:3000
BE_SERVER_BASE_URL=http://localhost:3000

# --- Docker một image (./run-docker.sh: -p 8003:8003 -p 8000:8000) ---
# Trong container: ADK :8000 + chatbot :8003; entrypoint set AGENT_SERVER_HOST=127.0.0.1 nếu không ghi AGENT_* → KHÔNG lỗi cổng nội bộ.
# Máy host gọi chatbot: AGENTIC_CHATBOT_BASE_URL=http://127.0.0.1:8003 (trùng CHATBOT_HOST_PORT).
# QUAN TRỌNG: DATABASE_URL=...@localhost:5432 trong container là SAI (localhost = chính container, không phải Postgres trên host).
# Dùng cùng DB với Prisma, host thật: postgresql://USER:PASS@host.docker.internal:5432/DB?schema=public

# Cùng DATABASE_URL với backend Prisma — FAQ Agent dùng pgvector (cột embedding).
# DATABASE_URL=postgresql://eaai:...@localhost:5432/eaai_com
# Hoặc tách: BE_SERVER_SCHEME, BE_SERVER_HOST, BE_SERVER_PORT

# Trùng với AGENT_INTEGRATION_SECRET trên backend Node (bắt buộc khi BE bật middleware).
# AGENT_INTEGRATION_SECRET=

# Tên app ADK (adk web agents + Runner + /run). Mặc định: agents
# ADK_APP_NAME=agents
# Tắt “thinking budget” trên manager agent (bắt buộc gần như khi dùng OpenRouter/LiteLLM — tránh ADK /run 500).
# Khi có OPENROUTER_API_KEY, code đã tự tắt thinking; chỉ cần ghi đè nếu dùng Gemini trực tiếp:
# ADK_DISABLE_THINKING=1

# Chatbot → ADK (chạy hai process trên host: ADK 8000, chatbot 8003)
# AGENT_SERVER_HOST=127.0.0.1
# AGENT_SERVER_PORT=8000
# hoặc: AGENT_SERVER_BASE_URL=http://127.0.0.1:8000
# Docker một container: có thể bỏ trống — entrypoint dùng 127.0.0.1 + AGENT_SERVER_PORT

# LLM — Gemini (mặc định nếu OPENROUTER_API_KEY rỗng)
GOOGLE_API_KEY=
MODEL_ID=gemini-2.0-flash

# Hoặc OpenRouter (ưu tiên khi có key)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ID=
# Embedding FAQ (pgvector 1536 chiều — khớp OPENROUTER_EMBEDDING_MODEL)
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# FAQ_EMBEDDING_DIMENSION=1536
# FAQ_USE_PGVECTOR=1

# --- FAQ Agent (agent đầu tiên trước ADK; FAQ lưu PostgreSQL, BE GET /faq) ---
# FAQ_AGENT_ENABLED=1
# FAQ_EMBEDDING_THRESHOLD=0.72
# FAQ_CACHE_TTL_SEC=60
# Embedding: ưu tiên OpenRouter nếu có OPENROUTER_API_KEY
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Hoặc ép: FAQ_EMBEDDING_BACKEND=openrouter | local
# FAQ_LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Fallback file khi BE chưa có dữ liệu: FAQ_JSON_PATH=... (mặc định agent-assistant/data/faq.json)

# --- Ingestor (port 8001) ---
# Cùng DATABASE_URL với backend Prisma để đẩy majors/subjects vào PostgreSQL.
# Trong Docker: bật INGESTOR_ENABLED=1 và publish -p 8001:8001 (mặc định không chạy ingestor).
# DATABASE_URL=postgresql://...
# INGESTOR_ENABLED=1
# INGESTOR_PORT=8001
# INGESTOR_SYNC_DB=1
