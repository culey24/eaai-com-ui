# Sao chép: cp prod.compose.env.example .env.deploy
# Chạy: docker compose -f docker-compose.prod.yml --env-file .env.deploy up -d --build

# Bắt buộc — đổi trên môi trường thật
POSTGRES_PASSWORD=thay-bang-mat-khau-db-manh
JWT_SECRET=thay-bang-chuoi-bi-mat-it-nhat-32-ky-tu

# URL API mà trình duyệt người dùng gọi được (không dùng tên service Docker).
# Ví dụ chạy compose trên máy local:
#   VITE_API_URL=http://localhost:3000
# Ví dụ có tên miền:
#   VITE_API_URL=https://api.example.com
VITE_API_URL=http://localhost:3000

# Gốc SPA (ngăn cách bằng dấu phẩy nếu nhiều). Khớp URL người dùng mở UI.
# Ví dụ local:
#   CORS_ORIGINS=http://localhost:8080
# Production:
#   CORS_ORIGINS=https://eaai-com-ui.vercel.app
CORS_ORIGINS=http://localhost:8080

# Tuỳ chọn
JWT_EXPIRES_IN=7d
API_PORT=3000
WEB_PORT=8080
# Đặt 1 nếu API đứng sau reverse proxy (Nginx, Cloudflare, …)
TRUST_PROXY=0

# Tuỳ chọn — chat Gemini qua OpenRouter cho kênh IS-2 (persona AGENT tư vấn, không nhúng journal)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_HTTP_REFERER=https://eaai-com-ui.vercel.app
