# URL API backend (auth JWT, chat kênh polling, …)
VITE_API_URL=http://localhost:3000

# PRETEST: 0 / false = bỏ qua gate + không gọi GET /api/me/pretest (SPA chỉ đọc VITE_*; đồng bộ khi backend PRETEST_ENABLED=0 lúc debug).
# VITE_PRETEST_ENABLED=0

# true = khi API lỗi vẫn cho đăng nhập/đăng ký mock (localStorage). Production nên false.
VITE_ENABLE_MOCK_AUTH=false
