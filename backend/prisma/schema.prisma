// PostgreSQL — căn theo backend/init/*.sql.
// eeai_chatbot_messages (localStorage) → conversations + messages
// eeai_chatbot_reports → content_reports
// Admin: learner_supporter_assignments, support_requests, app_settings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  assistant
  student
  admin
  support

  @@map("user_role_enum")
}

enum UserClass {
  IS_1 @map("IS-1")
  IS_2 @map("IS-2")
  IS_3 @map("IS-3")

  @@map("user_class_enum")
}

enum Gender {
  Male
  Female
  Other

  @@map("gender_enum")
}

enum MessageSender {
  user
  assistant
  system

  @@map("message_sender_enum")
}

enum ReportStatus {
  open
  reviewed
  dismissed

  @@map("report_status_enum")
}

enum SupportRequestStatus {
  pending
  approved
  rejected

  @@map("support_request_status_enum")
}

enum TeachingMode {
  AGENT
  LLM
  MANUAL

  @@map("teaching_mode_enum")
}

enum AgentSessionStatus {
  active
  deactive

  @@map("agent_session_status_enum")
}

enum AgentChatRole {
  user
  model
  TA

  @@map("agent_chat_role_enum")
}

model Major {
  majorCode String @id @map("major_code") @db.VarChar(7)
  majorName String @map("major_name") @db.VarChar(200)

  users User[]

  @@map("majors")
}

model User {
  userId                String    @id @map("user_id") @db.VarChar(10)
  username              String    @unique @db.VarChar(50)
  pwd                   String    @db.VarChar(255)
  fullname              String    @db.VarChar(100)
  userRole              UserRole  @map("user_role")
  dateOfBirth           DateTime  @map("date_of_birth") @db.Date
  gender                Gender
  majorCode             String    @map("major") @db.VarChar(7)
  trainingProgramType   String    @map("training_program_type") @db.VarChar(100)
  citizenIdentification String?   @unique @map("citizen_identification") @db.VarChar(20)
  dateOfIssue           DateTime? @map("date_of_issue") @db.Date
  placeOfIssue          String?   @map("place_of_issue") @db.VarChar(100)
  ethnicity             String?   @db.VarChar(50)
  religion              String?   @db.VarChar(50)
  permanentAddress      String?   @map("permanent_address") @db.VarChar(255)
  contactAddress        String?   @map("contact_address") @db.VarChar(255)
  phoneNumber           String?   @map("phone_number") @db.VarChar(15)
  email                 String?   @unique @db.VarChar(100)
  userClass             UserClass? @map("user_class")
  /// MSSV / mã sinh viên hiển thị trên UI (khác citizen_identification)
  studentSchoolId       String?   @map("student_school_id") @db.VarChar(32)
  faculty               String?   @db.VarChar(200)
  /// Tên ngành tự do (UI); majorCode vẫn là FK bắt buộc tới bảng majors
  majorDisplay          String?   @map("major_display") @db.VarChar(200)
  subjectNote           String?   @map("subject_note") @db.VarChar(255)

  major Major @relation(fields: [majorCode], references: [majorCode])

  assistantScopes            AssistantManagedClass[]       @relation("AssistantScopes")
  conversationsAsLearner     Conversation[]              @relation("ConversationLearner")
  messagesAsSender           Message[]                     @relation("MessageSender")
  reportsAuthored            ContentReport[]               @relation("ReportReporter")
  assignmentAsLearner        LearnerSupporterAssignment?   @relation("AssignmentLearner")
  assignmentsAsSupporter     LearnerSupporterAssignment[]  @relation("AssignmentSupporter")
  supportRequestsAsSupporter SupportRequest[]              @relation("SupportSupporter")
  supportRequestsAsLearner   SupportRequest[]              @relation("SupportLearner")
  journalPeriodsCreated      JournalPeriod[]               @relation("JournalPeriodCreator")
  journalUploads             JournalUpload[]
  agentSessions   AgentSession[]
  surveyResponses SurveyResponse[]

  // init SQL: CREATE TABLE Users → PostgreSQL lưu là public.users (không phải bảng "User" của Prisma mặc định)
  @@map("users")
}

/// Khảo sát học viên PRE/POST — cùng bảng pretest_responses, phân biệt survey_kind (mở rộng POSTTEST sau).
model SurveyResponse {
  id         BigInt   @id @default(autoincrement()) @map("pretest_id")
  userId     String   @map("user_id") @db.VarChar(10)
  surveyKind String   @default("PRETEST") @map("survey_kind") @db.VarChar(32)
  sectionA   Json     @map("section_a")
  sectionB   Json     @map("section_b")
  sectionC   Json     @map("section_c")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, surveyKind])
  @@index([surveyKind])
  @@map("pretest_responses")
}

/// Đợt nộp journal (submission window). Production: không FK tới Classes — class_id tuỳ chọn, text.
model JournalPeriod {
  periodId    String   @id @map("period_id") @db.VarChar(64)
  title       String   @db.VarChar(255)
  description String   @default("") @db.Text
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  classId     String?  @map("class_id") @db.VarChar(50)
  createdBy   String?  @map("created_by") @db.VarChar(10)
  createdAt   DateTime @default(now()) @map("created_at")

  creator User?           @relation("JournalPeriodCreator", fields: [createdBy], references: [userId], onDelete: SetNull)
  uploads JournalUpload[]

  @@map("journal_periods")
}

model JournalUpload {
  id               BigInt   @id @default(autoincrement()) @map("upload_id")
  userId           String   @map("user_id") @db.VarChar(10)
  periodId         String   @map("period_id") @db.VarChar(64)
  storageKey       String   @map("storage_key") @db.VarChar(512)
  originalFileName String?  @map("original_file_name") @db.VarChar(512)
  submittedAt      DateTime @default(now()) @map("submitted_at")
  status           String   @default("submitted") @db.VarChar(32)
  extractedText    String?  @map("extracted_text") @db.Text

  user   User          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  period JournalPeriod @relation(fields: [periodId], references: [periodId], onDelete: Cascade)

  @@index([userId, periodId])
  @@map("journal_uploads")
}

model ChatChannel {
  channelId    String    @id @map("channel_id") @db.VarChar(64)
  userClass    UserClass @unique @map("user_class")
  displayOrder Int       @default(0) @map("display_order")

  conversations Conversation[]
  reports       ContentReport[]

  @@map("chat_channels")
}

model AssistantManagedClass {
  id          Int       @id @default(autoincrement())
  supporterId String    @map("supporter_id") @db.VarChar(10)
  userClass   UserClass @map("user_class")

  supporter User @relation("AssistantScopes", fields: [supporterId], references: [userId], onDelete: Cascade)

  @@unique([supporterId, userClass])
  @@map("assistant_managed_classes")
}

model Conversation {
  id        BigInt @id @default(autoincrement()) @map("conversation_id")
  channelId String @map("channel_id") @db.VarChar(64)
  learnerId String @map("learner_id") @db.VarChar(10)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel  ChatChannel @relation(fields: [channelId], references: [channelId], onDelete: Cascade)
  learner  User        @relation("ConversationLearner", fields: [learnerId], references: [userId], onDelete: Cascade)
  messages Message[]

  @@unique([channelId, learnerId])
  @@map("conversations")
}

model Message {
  id             BigInt        @id @default(autoincrement()) @map("message_id")
  conversationId BigInt        @map("conversation_id")
  senderRole     MessageSender @map("sender_role")
  senderUserId   String?       @map("sender_user_id") @db.VarChar(10)
  content        String        @default("") @db.Text
  fileName       String?       @map("file_name") @db.VarChar(512)
  metadata       Json          @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?         @relation("MessageSender", fields: [senderUserId], references: [userId], onDelete: SetNull)
  reports      ContentReport[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ContentReport {
  id         BigInt       @id @default(autoincrement()) @map("report_id")
  reporterId String       @map("reporter_id") @db.VarChar(10)
  channelId  String?      @map("channel_id") @db.VarChar(64)
  messageId  BigInt?      @map("message_id")
  reportType String       @map("report_type") @db.VarChar(64)
  detail     String?      @db.Text
  status     ReportStatus @default(open)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reporter User         @relation("ReportReporter", fields: [reporterId], references: [userId], onDelete: Cascade)
  channel  ChatChannel? @relation(fields: [channelId], references: [channelId], onDelete: SetNull)
  message  Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@map("content_reports")
}

model LearnerSupporterAssignment {
  learnerId    String       @id @map("learner_id") @db.VarChar(10)
  supporterId  String       @map("supporter_id") @db.VarChar(10)
  teachingMode TeachingMode @default(MANUAL) @map("teaching_mode")
  assignedAt   DateTime     @default(now()) @map("assigned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  learner   User @relation("AssignmentLearner", fields: [learnerId], references: [userId], onDelete: Cascade)
  supporter User @relation("AssignmentSupporter", fields: [supporterId], references: [userId], onDelete: Cascade)

  @@map("learner_supporter_assignments")
}

model SupportRequest {
  id          BigInt               @id @default(autoincrement()) @map("request_id")
  supporterId String               @map("supporter_id") @db.VarChar(10)
  learnerId   String               @map("learner_id") @db.VarChar(10)
  classCode   UserClass            @map("class_code")
  status      SupportRequestStatus @default(pending)
  resolvedAt  DateTime?            @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supporter User @relation("SupportSupporter", fields: [supporterId], references: [userId], onDelete: Cascade)
  learner   User @relation("SupportLearner", fields: [learnerId], references: [userId], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("support_requests")
}

model AppSetting {
  settingKey String @id @map("setting_key") @db.VarChar(128)
  value      Json   @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

/// Phiên chatbot/agent (UUID); song song với bảng conversations của web app.
model AgentSession {
  sessionId String             @id @map("session_id") @db.Uuid
  userId    String             @map("user_id") @db.VarChar(10)
  status    AgentSessionStatus @default(active) @map("session_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User                  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  messages AgentSessionMessage[]

  @@index([userId])
  @@map("agent_sessions")
}

model AgentSessionMessage {
  id              BigInt       @id @default(autoincrement()) @map("message_id")
  sessionId       String       @map("session_id") @db.Uuid
  chatRole        AgentChatRole @map("chat_role")
  content         String       @default("") @db.Text
  fileIds         Json?        @map("file_ids") @db.JsonB
  dynamicProfile  String?      @map("dynamic_profile") @db.Text
  tokensCount     Int?         @map("tokens_count")

  createdAt DateTime @default(now()) @map("created_at")

  session AgentSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("agent_session_messages")
}
