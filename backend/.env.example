# =============================================================================
# BACKEND .env — sao chép thành backend/.env và điền giá trị thật (không commit .env)
# =============================================================================

# --- BẮT BUỘC (local / production) ---
DATABASE_URL="postgresql://eaai:eaai_dev_change_me@localhost:5432/eaai_com?schema=public"
JWT_SECRET=thay-bang-chuoi-bi-mat-it-nhat-32-ky-tu

# --- API ---
PORT=3000
JWT_EXPIRES_IN=7d
# Giới hạn thời gian chờ DB trong GET /health (ms). Railway: tránh treo vô hạn.
# HEALTH_DB_TIMEOUT_MS=4000

# Docker/Railway: bỏ qua prisma migrate trong entrypoint (chỉ khi debug).
# SKIP_DB_MIGRATE=1

# --- Production / reverse proxy ---
# CORS_ORIGINS=https://eaai-com-ui.vercel.app,http://localhost:5173
# (chỉ origin, không thêm /login — trình duyệt không gửi path trong Origin)
# TRUST_PROXY=1

# --- OpenRouter (Gemini) — kênh human-chat (học viên đăng ký IS-3 sau khi hoán vai lớp) ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://eaai-com-ui.vercel.app
# OPENROUTER_APP_TITLE=eaai-com-backend
# OPENROUTER_MAX_TOKENS=1024
# OPENROUTER_TEMPERATURE=0.6

# --- Bootstrap admin khi deploy (tùy chọn) ---
# Không bật mặc định. Khi ENSURE_DEFAULT_ADMIN=1: lần đầu có DB trống sẽ tạo admin (bcrypt),
# nếu username/userId đã tồn tại thì không đổi mật khẩu (khác với chạy tay init/ensure_admin_user.sql).
# Production: bắt buộc đặt ADMIN_BOOTSTRAP_PASSWORD (chuỗi mạnh).
# ENSURE_DEFAULT_ADMIN=1
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_USER_ID=A00001
# ADMIN_BOOTSTRAP_PASSWORD=
# ADMIN_BOOTSTRAP_FULLNAME=Quản trị hệ thống

# --- Khảo sát PRETEST / POST-TEST (học viên) ---
# PRETEST: mặc định bật (hoặc PRETEST_ENABLED=1). Đặt 0 / false / off để tắt gate ứng dụng và từ chối POST nộp bài.
# PRETEST_ENABLED=1
# SPA (Vite): khi tắt PRETEST lúc dev, đặt thêm frontend/.env — VITE_PRETEST_ENABLED=0 (bundle không đọc file .env này).
#
# POST-TEST: bật nộp bài khi đã triển khai API + UI (cùng bảng pretest_responses, survey_kind = POSTTEST).
# SURVEY_POSTTEST_ENABLED=1

# --- Journal upload (file + trích văn bản) ---
# JOURNAL_UPLOAD_DIR=uploads/journals
# JOURNAL_MAX_FILE_BYTES=20971520
# JOURNAL_MAX_EXTRACT_CHARS=400000
# JOURNAL_CONTEXT_PER_FILE_CHARS=16000
# JOURNAL_CONTEXT_TOTAL_CHARS=80000

# --- Giới hạn tốc độ (rate limit) — chống spam / gọi API quá nhanh ---
# Tắt toàn bộ (chỉ dev): RATE_LIMIT_DISABLED=1
#
# Mọi request /api/* theo IP (phút):
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_API_MAX=300
#
# POST /api/auth/login và /register theo IP (mặc định 15 phút):
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=40
#
# POST /api/messages — chat tối giản (không JWT), theo IP / phút:
# RATE_LIMIT_MSG_MINIMAL_WINDOW_MS=60000
# RATE_LIMIT_MSG_MINIMAL_MAX=45
#
# POST /api/messages — có JWT (learner gửi tin + có thể gọi LLM), theo userId / phút:
# RATE_LIMIT_MSG_USER_WINDOW_MS=60000
# RATE_LIMIT_MSG_USER_MAX=24
#
# Học viên + human-chat (IS-3) → Gemini: mỗi userId, tối đa MAX lần mỗi WINDOW (ms)
# RATE_LIMIT_IS2_GEMINI_WINDOW_MS=60000
# RATE_LIMIT_IS2_GEMINI_MAX=12
#
# POST /api/journal/upload theo user / giờ:
# RATE_LIMIT_JOURNAL_WINDOW_MS=3600000
# RATE_LIMIT_JOURNAL_MAX=40
#
# POST /api/reports theo user / 15 phút:
# RATE_LIMIT_REPORT_WINDOW_MS=900000
# RATE_LIMIT_REPORT_MAX=30

# --- Chỉ khi dùng docker compose DB từ README (tuỳ chọn) ---
POSTGRES_PASSWORD=eaai_dev_change_me
POSTGRES_PORT=5432
